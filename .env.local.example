# UFC Predictor backend config.
# Скопируй в `.env.local` и заполни своими значениями.
# Файл .env.local исключён из git через .gitignore.

# OpenAI-compatible endpoint (Groq / OpenAI / Together / vLLM / своя модель)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# Опционально: имя для отображения в UI
LLM_DISPLAY_NAME=Octagon Oracle LLM

# ─── Realtime Odds API ───────────────────────────────────────────────
# TheOddsAPI — https://the-odds-api.com/ (free 500 req/мес)
# Зарегистрируйся → получи API key → вставь сюда
THE_ODDS_API_KEY=your_odds_api_key_here
